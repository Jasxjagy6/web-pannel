# =============================================================================
# Caddyfile — public-facing reverse proxy for web-pannel.
#
# This file is loaded by Caddy at boot. After boot, the upgrade orchestrator
# (`bin/upgrade`) edits the upstream targets at runtime through Caddy's admin
# API on 127.0.0.1:2019 — this file is only the SEED config, never the live
# truth during a deploy.
#
# Two upstream colors exist (backend-blue and backend-green); only one is
# active at any moment. The orchestrator atomically replaces the
# `reverse_proxy` upstream and Caddy drains existing connections gracefully.
#
# `{$VAR}` placeholders are substituted by Caddy from environment variables at
# load time (provided through docker-compose).
#
# To change the active color, do NOT edit this file by hand. Use:
#   ./bin/upgrade deploy --ref <branch|sha>
# or:
#   ./bin/upgrade rollback
# =============================================================================

{
	# Admin API — bound to localhost on the Caddy container only. The
	# orchestrator reaches it through the docker network on
	# http://caddy:2019. Never exposed publicly.
	admin 0.0.0.0:2019

	# Caddy auto-TLS is configured by the orchestrator at runtime via the
	# admin API JSON config (see proxy/caddyClient.js). The seed file only
	# binds :80 so that bringing the stack up never requires a public DNS
	# name or ACME email. To use HTTPS, set PUBLIC_DOMAIN + ACME_EMAIL in
	# .env, then run `./bin/upgrade deploy ...` once — the orchestrator
	# will POST the TLS config and Caddy will start :443.
	auto_https off
}

# Public site (HTTP-only seed; orchestrator adds TLS when configured).
:80 {
	# /api/* and /socket.io/* go to the active backend color.
	# DEFAULT seed: backend-blue. The orchestrator rewrites this on every
	# deploy.
	@api {
		path /api/*
		path /socket.io/*
		path /socket.io/*/*
		# Public health checks hit the backend through Caddy too — useful
		# for external uptime monitors and for the operator to verify the
		# active color from outside the docker network.
		path /health
		path /health/*
	}
	handle @api {
		reverse_proxy {$ACTIVE_BACKEND:backend-blue:3005} {
			# Long-lived Socket.IO upgrades.
			transport http {
				keepalive 30s
				keepalive_idle_conns 64
				dial_timeout 5s
				response_header_timeout 0s
			}
			# Health probe — Caddy will mark the upstream down if /health
			# stops returning 200, and that triggers a 503 instead of a hung
			# request. The orchestrator never relies on this for cutover; it
			# uses /health/ready directly.
			health_uri /health
			health_interval 10s
			health_timeout 2s
			health_status 200

			# Caddy already sets X-Forwarded-Proto, X-Forwarded-For, and
			# Host on every reverse_proxy by default. We only need to add
			# X-Real-IP because some downstream code paths look for it.
			header_up X-Real-IP {remote_host}
		}
	}

	# Everything else → static SPA from the active frontend color. The
	# orchestrator rewrites this on every deploy via the admin API the
	# same way it does for /api/*. Default seed is frontend-blue.
	handle {
		reverse_proxy {$ACTIVE_FRONTEND:frontend-blue:83} {
			# Active health check: nginx serves "/" with a 200 once the
			# SPA bundle is mounted. Caddy will mark the upstream down
			# if "/" stops returning 200, which is enough to fall back
			# to a 502 instead of a hung request while the new color
			# is starting up. The orchestrator uses the docker
			# healthcheck (not this) for cutover gating.
			health_uri /
			health_interval 10s
			health_timeout 2s
			health_status 200
		}
	}

	encode gzip zstd

	log {
		output stdout
		format json
		level INFO
	}
}
