# =============================================================================
# Caddyfile — public-facing reverse proxy for web-pannel.
#
# This file is loaded by Caddy at boot. After boot, the upgrade orchestrator
# (`bin/upgrade`) edits the upstream targets at runtime through Caddy's admin
# API on 127.0.0.1:2019 — this file is only the SEED config, never the live
# truth during a deploy.
#
# Two upstream colors exist (backend-blue and backend-green); only one is
# active at any moment. The orchestrator atomically replaces the
# `reverse_proxy` upstream and Caddy drains existing connections gracefully.
#
# `{$VAR}` placeholders are substituted by Caddy from environment variables at
# load time (provided through docker-compose).
#
# To change the active color, do NOT edit this file by hand. Use:
#   ./bin/upgrade deploy --ref <branch|sha>
# or:
#   ./bin/upgrade rollback
# =============================================================================

{
	# Admin API — bound to localhost on the Caddy container only. The
	# orchestrator reaches it through the docker network on
	# http://caddy:2019. Never exposed publicly.
	admin 0.0.0.0:2019

	# Auto-TLS via Let's Encrypt when PUBLIC_DOMAIN is set. For local /
	# IP-only deployments the operator can keep this empty and Caddy
	# will serve plain HTTP on :80.
	email {$ACME_EMAIL:admin@localhost}
}

# Public site
:80, {$PUBLIC_DOMAIN:localhost}:443 {
	# /api/* and /socket.io/* go to the active backend color.
	# DEFAULT seed: backend-blue. The orchestrator rewrites this on every
	# deploy.
	@api {
		path /api/*
		path /socket.io/*
		path /socket.io/*/*
	}
	handle @api {
		reverse_proxy {$ACTIVE_BACKEND:backend-blue:3005} {
			# Long-lived Socket.IO upgrades.
			transport http {
				keepalive 30s
				keepalive_idle_conns 64
				dial_timeout 5s
				response_header_timeout 0s
			}
			# Health probe — Caddy will mark the upstream down if /health
			# stops returning 200, and that triggers a 503 instead of a hung
			# request. The orchestrator never relies on this for cutover; it
			# uses /health/ready directly.
			health_uri /health
			health_interval 10s
			health_timeout 2s
			health_status 200

			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For   {remote_host}
			header_up X-Real-IP         {remote_host}
			header_up Host              {host}
		}
	}

	# Everything else → static SPA from the frontend container.
	handle {
		reverse_proxy frontend:83
	}

	encode gzip zstd

	log {
		output stdout
		format json
		level INFO
	}
}
