# =============================================================================
# Root .env — read by docker-compose.yml AND bin/upgrade.
# Copy to `.env` and customise. Backend-specific knobs live in backend/.env.
# =============================================================================

# ── Public hostname ─────────────────────────────────────────────────────────
# When set, Caddy issues a Let's Encrypt cert and serves :443. Leave empty
# for HTTP-only / IP-based deployments.
PUBLIC_DOMAIN=
ACME_EMAIL=

# ── Database / Redis passwords (read by docker-compose.yml) ─────────────────
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────────────────
# Shared secret for signing JSON Web Tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# ── Caddy / blue-green ──────────────────────────────────────────────────────
# Which color Caddy points at on cold boot. The orchestrator overrides this
# via the admin API on every deploy.
ACTIVE_BACKEND=backend-blue:3005
ACTIVE_FRONTEND=frontend-blue:83

# Public ports the Caddy reverse proxy listens on, ON THE VPS HOST.
# Override when ports 80/443 are already taken by another service.
# IMPORTANT: only change values here. Do NOT edit docker-compose.yml — the
# right side of the ports mapping is the port INSIDE the Caddy container.
HTTP_PORT=80
HTTPS_PORT=443

# ── Build / image tags ──────────────────────────────────────────────────────
# Set automatically by bin/upgrade. Override only for manual docker compose.
GIT_SHA=dev
GIT_REF=unknown
BUILD_TIME=unknown
IMAGE_TAG=dev
FRONTEND_IMAGE_TAG=

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
SKIP_BOOT_MIGRATIONS=false

# ── bin/upgrade orchestrator ────────────────────────────────────────────────
# When set, --build registry pulls images from this GHCR path. Leave empty to
# default to local-build mode.
UPGRADE_REGISTRY=

# How long to wait for /health/ready on the staged color before aborting.
ROLLOUT_HEALTH_TIMEOUT_MS=120000

# How long to wait for the frontend health check during deploy.
FRONTEND_HEALTH_TIMEOUT_MS=60000

# How long to leave the OLD color running after Caddy flips, so live WS
# clients can reconnect cleanly. Should be >= backend SHUTDOWN_GRACE_MS.
DRAIN_GRACE_MS=25000

# Set to "true" to skip building/deploying the frontend during upgrades.
UPGRADE_SKIP_FRONTEND=false

# Set to "false" to make backup failures non-fatal during deploy.
BACKUP_REQUIRED=true

# Number of historical backups to keep under ./backups/.
BACKUP_RETAIN=10

# Set to "true" to verify session files haven't been tampered with before
# a deploy proceeds. Requires SESSION_SAFETY_BASELINE_DIR.
SESSION_SAFETY_VERIFY=false
SESSION_SAFETY_BASELINE_DIR=/var/lib/web-pannel

# ── Docker compose paths (advanced) ────────────────────────────────────────
# Override if docker compose is installed under a different binary name or
# the stack runs on a non-default docker network.
# COMPOSE_BIN=docker
# COMPOSE_NETWORK=

# Override the directory where upgrade state and audit logs are stored.
# UPGRADE_STATE_DIR=
# UPGRADE_LOG_DIR=

# Override the DB connection used by bin/upgrade audit queries (runs on the
# host, not inside a container, so it needs the mapped host port).
# UPGRADE_DB_HOST=127.0.0.1
# UPGRADE_DB_PORT=
# MIGRATE_DB_HOST=postgres

# ── Telegram admin bot ──────────────────────────────────────────────────────
# Create a bot via @BotFather, paste the token here, and add the numeric IDs
# of every Telegram user who is allowed to run upgrade commands. You can
# find your numeric ID by messaging @userinfobot.
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Optional second factor: when set, destructive commands require the user to
# append `PIN=<value>` to their message. Recommended for production.
UPGRADE_CONFIRM_PIN=
