# =============================================================================
# Root .env (used by docker-compose AND bin/upgrade) — copy to `.env` and
# customise. Backend-specific knobs still live in backend/.env.
# =============================================================================

# ── Public hostname ─────────────────────────────────────────────────────────
# When set, Caddy issues a Let's Encrypt cert and serves :443. Leave empty
# for HTTP-only / IP-based deployments.
PUBLIC_DOMAIN=
ACME_EMAIL=

# ── Database / Redis passwords (read by docker-compose.yml) ─────────────────
# These default to the legacy values to avoid breaking existing deployments.
# Set them in the host environment to override.
POSTGRES_PASSWORD=Navneetbb1###@
REDIS_PASSWORD=Navneetbb1###
JWT_SECRET=

# ── Caddy / blue-green ──────────────────────────────────────────────────────
# Which color Caddy points at on cold boot. The orchestrator overrides this
# via the admin API on every deploy. Default: backend-blue.
ACTIVE_BACKEND=backend-blue:3005

# Public ports the Caddy reverse proxy listens on, ON THE VPS HOST.
# Override these when ports 80 / 443 are already taken by another service on
# the VPS (nginx, Apache, another stack, Cloudflare tunnel, etc.).
#
# IMPORTANT: only change values here in `.env`. Do NOT edit
# `docker-compose.yml` — the right side of the `ports:` mapping (`:80` and
# `:443`) is the port INSIDE the Caddy container, which is hardcoded to
# `:80` in `proxy/Caddyfile` and must stay 80/443. Editing the right side
# breaks the inbound connection and every request will return a 502 / a
# refused connection.
#
# Example: VPS already running another web server on :80, expose this stack
# on :81 instead:
#   HTTP_PORT=81
#   HTTPS_PORT=444
# Then visit it at  http://<vps-host>:81/  (with the explicit port).
HTTP_PORT=80
HTTPS_PORT=443

# ── bin/upgrade orchestrator ────────────────────────────────────────────────
# When set, --build registry pulls images from this GHCR path. Leave empty to
# default to local-build mode.
UPGRADE_REGISTRY=

# How long to wait for /health/ready on the staged color before aborting.
ROLLOUT_HEALTH_TIMEOUT_MS=120000

# How long to leave the OLD color running after Caddy flips, so live WS
# clients can reconnect cleanly. Should be >= backend SHUTDOWN_GRACE_MS.
DRAIN_GRACE_MS=25000

# Set to "false" to make backup failures non-fatal during deploy.
BACKUP_REQUIRED=true

# Number of historical backups to keep under ./backups/.
BACKUP_RETAIN=10

# ── Telegram admin bot ──────────────────────────────────────────────────────
# Create a bot via @BotFather, paste the token here, and add the numeric IDs
# of every Telegram user who is allowed to run upgrade commands. You can
# find your numeric ID by messaging @userinfobot.
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Optional second factor: when set, destructive commands require the user to
# append `PIN=<value>` to their message. Recommended for production.
UPGRADE_CONFIRM_PIN=
