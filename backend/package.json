{
  "name": "telegram-panel-backend",
  "version": "1.0.0",
  "description": "Telegram Session Management Panel - Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "node src/config/database.js --migrate",
    "session-worker": "node src/workers/sessionWorker.js",
    "verify-sessions": "node scripts/verify-sessions.js",
    "check-migration-safety": "node scripts/check-migration-safety.js",
    "test:smoke:telegram": "for f in test/telegram/*.test.js; do echo \"--- $f ---\" && node \"$f\" || exit 1; done"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.4.3",
    "bullmq": "^4.12.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-stringify": "^6.4.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "formidable": "^3.5.1",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "instagram-private-api": "^1.46.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "telegram": "^2.22.2",
    "undici": "^6.25.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
