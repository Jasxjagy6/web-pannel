# Server
PORT=3000
NODE_ENV=production
API_PREFIX=/api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telegram_panel
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_EXPIRE=7d

# Telegram API
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Upload
MAX_UPLOAD_SIZE=500MB
UPLOAD_DIR=./uploads

# Rate Limiting (per IP, per window). Defaults are tuned for shared
# admin credentials with multiple browsers polling at the same time.
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=5000
AUTH_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_MAX=500
MESSAGE_RATE_LIMIT_MAX=200
SCRAPE_RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================================
# Billing — OxaPay crypto payments
# ============================================================
# Generate a Merchant API key from your OxaPay dashboard:
#   https://oxapay.com → Merchant Service → "Generate Merchant API Key"
# This same key is used to:
#   1. Authenticate outgoing API calls (sent in the `merchant_api_key` header)
#   2. Verify incoming webhook signatures (sha512 HMAC of the raw request body)
OXAPAY_MERCHANT_API_KEY=

# Override the API base URL only if OxaPay rotates it. The default is fine
# for production; you do NOT need to change this for sandbox.
OXAPAY_BASE_URL=https://api.oxapay.com/v1

# Webhook OxaPay POSTs to when a payment status changes. This MUST be a
# public URL reachable from oxapay.com (use your domain or an ngrok tunnel
# in development). If not set the create-invoice call will still work but
# OxaPay won't notify you of paid invoices, so the user has to press
# "I paid" to trigger a refresh.
OXAPAY_CALLBACK_URL=https://your-domain.example/api/billing/oxapay/ipn

# Where the user is redirected after a successful payment. Typically the
# Billing page on your frontend.
OXAPAY_RETURN_URL=https://your-domain.example/billing?status=success

# Set to "true" to put OxaPay in sandbox/test mode (no real funds move).
# Leave unset / "false" for production.
OXAPAY_SANDBOX=false

# Invoice lifetime in MINUTES — the customer has this long to pay before
# the invoice expires. Min 15, max 2880. Default 60 if unset.
OXAPAY_INVOICE_LIFETIME_MIN=60
