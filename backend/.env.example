# Server
# All service ports were bumped by +3 from the originals
# (3000 -> 3003, 5432 -> 5435, 6379 -> 6382, 5173 -> 5176, 8080 -> 8083).
# Backend was further bumped to 3005 because port 3003 was already
# allocated on the operator's host.
# See OPS.md §11 for the procedure to shift them again.
PORT=3005
NODE_ENV=production
API_PREFIX=/api

# Database
DB_HOST=localhost
DB_PORT=5435
DB_NAME=telegram_panel
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_EXPIRE=7d

# Telegram API
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ── PEER_FLOOD safety cooldown ──────────────────────────────────────────────
# Telegram does NOT return a duration with the `PEER_FLOOD` error — it's an
# account-level spam flag that lifts whenever Telegram's spam algorithms
# decide. Set this to a positive number of seconds to apply an opt-in
# panel-side cooldown (sessions are skipped for group-add / bulk-message
# jobs for this many seconds after PEER_FLOOD). Login / 2FA / privacy /
# delete actions stay enabled regardless. Default 0 = no panel-side
# cooldown (trust Telegram). Example: 21600 = 6 hours (the legacy hardcoded
# value that was always being applied prior to this knob existing).
# PEER_FLOOD_COOLDOWN_SECONDS=0

# Upload
MAX_UPLOAD_SIZE=500MB
UPLOAD_DIR=./uploads

# Rate Limiting (per IP, per window). Defaults are tuned for shared
# admin credentials with multiple browsers polling at the same time.
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=5000
AUTH_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_MAX=500
MESSAGE_RATE_LIMIT_MAX=200
SCRAPE_RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================================
# Billing — OxaPay crypto payments
# ============================================================
# Generate a Merchant API key from your OxaPay dashboard:
#   https://oxapay.com → Merchant Service → "Generate Merchant API Key"
# This same key is used to:
#   1. Authenticate outgoing API calls (sent in the `merchant_api_key` header)
#   2. Verify incoming webhook signatures (sha512 HMAC of the raw request body)
OXAPAY_MERCHANT_API_KEY=

# Override the API base URL only if OxaPay rotates it. The default is fine
# for production; you do NOT need to change this for sandbox.
OXAPAY_BASE_URL=https://api.oxapay.com/v1

# Webhook OxaPay POSTs to when a payment status changes. This MUST be a
# public URL reachable from oxapay.com (use your domain or an ngrok tunnel
# in development). If not set the create-invoice call will still work but
# OxaPay won't notify you of paid invoices, so the user has to press
# "I paid" to trigger a refresh.
OXAPAY_CALLBACK_URL=https://your-domain.example/api/billing/oxapay/ipn

# Where the user is redirected after a successful payment. Typically the
# Billing page on your frontend.
OXAPAY_RETURN_URL=https://your-domain.example/billing?status=success

# Set to "true" to put OxaPay in sandbox/test mode (no real funds move).
# Leave unset / "false" for production.
OXAPAY_SANDBOX=false

# Invoice lifetime in MINUTES — the customer has this long to pay before
# the invoice expires. Min 15, max 2880. Default 60 if unset.
OXAPAY_INVOICE_LIFETIME_MIN=60

# ============================================================
# Multi-platform (v9+) — Instagram + Telegram queue knobs
# ============================================================
# Master switch — set to "false" to skip initializing the IG queues at
# boot (e.g. emergency rollback). IG endpoints will return 503.
IG_QUEUES_ENABLED=true

# Worker concurrency for the per-platform Instagram queues. Defaults
# are conservative because IG account-level rate limits are stricter
# than Telegram's. See OPS.md §10.2.
IG_SCRAPE_CONCURRENCY=3
IG_MESSAGING_CONCURRENCY=2

# Warmup is intentionally serial (warmup races trigger checkpoints).
IG_WARMUP_CONCURRENCY=1

# Optional override for the IG proxy validator's probe endpoint. Leave
# empty to use the default i.instagram.com smoke-test in
# providers/instagram/proxies.js::validate.
# IG_PROXY_VALIDATE_ENDPOINT=https://i.instagram.com/api/v1/users/web_profile_info/?username=instagram

# Hard cap on simultaneously running IG warmup / scrape jobs PER USER
# — protects shared workers from one runaway tenant. Mirror of
# MAX_RUNNING_MONITORS_PER_USER for IG.
IG_MAX_RUNNING_JOBS_PER_USER=20
