# =============================================================================
# Backend .env — copy to backend/.env and customise.
# Loaded by dotenv at startup (see src/index.js).
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3005
NODE_ENV=production
API_PREFIX=/api

# Allowed CORS origin for the frontend. Defaults to http://localhost:5176.
FRONTEND_URL=http://localhost:5176

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5435
DB_NAME=telegram_panel
DB_USER=postgres
DB_PASSWORD=

# Pool tuning — defaults are fine for most deployments.
# DB_POOL_MAX=50
# DB_POOL_IDLE_MS=30000
# DB_POOL_CONNECT_MS=5000
# DB_POOL_LIFETIME_SEC=600

# Set to "true" to skip running migrations at boot (e.g. when the
# orchestrator already ran them).
# SKIP_BOOT_MIGRATIONS=false

# Bootstrap admin account — created on first run if the users table is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=

# ── JWT / Encryption ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
JWT_EXPIRE=7d

# Separate key for encrypting session files at rest. Must differ from
# JWT_SECRET (the app warns at boot if they match).
# SESSION_ENCRYPTION_KEY=

# ── Telegram API ────────────────────────────────────────────────────────────
# Obtain from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Upload ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=500MB
UPLOAD_DIR=./uploads

# Absolute path override for session file uploads (used in production Docker).
# UPLOAD_DIR_ABS=

# Max upload size for the Telegram client feature (in MB).
# TG_CLIENT_MAX_UPLOAD_MB=

# ── Rate Limiting (per IP, per window in minutes) ──────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=5000
AUTH_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_MAX=500
MESSAGE_RATE_LIMIT_MAX=200
SCRAPE_RATE_LIMIT_MAX=200

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Sample 1-in-N requests for the access log. Set higher to reduce log volume.
# REQ_LOG_SAMPLE=20

# ── WebSocket ───────────────────────────────────────────────────────────────
# WS_PING_INTERVAL_MS=25000
# WS_PING_TIMEOUT_MS=20000

# ── Graceful shutdown ──────────────────────────────────────────────────────
# Time (ms) the server waits for in-flight requests before exiting.
# SHUTDOWN_GRACE_MS=20000

# ── Session management ─────────────────────────────────────────────────────
# SESSION_CREATION_TTL_MS=300000
# SESSION_LOGIN_TIMEOUT_MS=90000
# SESSION_GET_ME_TIMEOUT_MS=30000
# SESSION_RESTORE_PER_SESSION_TIMEOUT_MS=20000
# SESSION_RESTORE_WINDOW_MS=300000
# SESSION_RESTORE_PER_IP_PER_MIN=4
# SESSION_HEARTBEAT_INTERVAL_MS=120000
# SESSION_HEARTBEAT_JITTER_MS=25000
# SESSION_OFFLINE_AFTER_IDLE_MS=300000
# SESSION_ZIP_TOTAL_MAX_BYTES=1073741824

# Set to "true" to enforce strict session locking (only one process can hold
# a session at a time).
# STRICT_SESSION_LOCK=false
# SESSION_LOCK_HOLDER_ID=

# ── Session worker (sharding) ──────────────────────────────────────────────
# SHARD_ID=0
# SHARD_COUNT=1
# DRAIN_GRACE_MS=30000

# ── Telegram anti-revoke / security ────────────────────────────────────────
# ANTI_REVOKE_STRICT_FINGERPRINT=true
# ANTI_REVOKE_PHASE_1_ENABLED=true
# ANTI_REVOKE_PHASE_2_ENABLED=true
# ANTI_REVOKE_PHASE_3_ENABLED=true
# ANTI_REVOKE_PHASE_4_ENABLED=true
# ANTI_REVOKE_PHASE_4_CONSECUTIVE_REVOKE_THRESHOLD=2
# ANTI_REVOKE_PHASE_4_REVOKE_CONFIRM_WINDOW_MS=1800000
# ANTI_REVOKE_PHASE_4_CONSECUTIVE_EXTERNAL_REVOKE_THRESHOLD=2
# ANTI_REVOKE_PHASE_4_RECONFIRM_INTERVAL_MS=604800000
# ANTI_REVOKE_PHASE_4_RESET_ACCOUNT_TTL_INTERVAL_MS=2592000000
# ANTI_REVOKE_PHASE_4_ACCOUNT_TTL_DAYS=730
# ANTI_REVOKE_PHASE_4_BACKUP_RETENTION_DAYS=90
# ANTI_REVOKE_PHASE_4_ALERT_COOLDOWN_MS=600000
# ANTI_REVOKE_REQUIRE_SESSION_KEY=false

# ── Telegram connection tuning ─────────────────────────────────────────────
# TG_CONNECT_TIMEOUT_MS=
# TG_RISK_GATE_THRESHOLD=0.65
# AUTHORIZATIONS_PROBE_MS=14400000
# AUTHORIZATIONS_PROBE_JITTER_MS=7200000

# ── OTP Relay ───────────────────────────────────────────────────────────────
# OTP_RELAY_ENABLED=
# OTP_RELAY_DEFAULT_SENDERS=777000,Telegram
# OTP_RELAY_RATE_LIMIT_PER_MIN=30
# OTP_RELAY_EVENT_RETENTION_DAYS=30
# OTP_RELAY_DEFAULT_REGEX=

# ── Strict proxy isolation ─────────────────────────────────────────────────
# When "true", every session MUST have its own proxy — no sharing.
# STRICT_PROXY_ISOLATION=true

# ── Proxy ───────────────────────────────────────────────────────────────────
# REQUIRE_USER_PROXY=true
# PROXY_EGRESS_FINGERPRINT_URL=https://api.ipify.org?format=json
# PROXY_IG_PROBE_URL=https://i.instagram.com/api/v1/qe/sync/

# iProyal reseller API (for proxy provider integration).
# IPROYAL_RESELLER_URL=

# ── Messaging ───────────────────────────────────────────────────────────────
# RUNNER_V2_ENABLED=true
# MAX_CONCURRENT_SESSIONS=200
# PRIVACY_QUORUM=1
# SCHEDULE_TICK_INTERVAL_MS=30000
# SCHEDULE_MAX_RUNNING_PER_USER=100
# MAX_RUNNING_MONITORS_PER_USER=20

# ── Clone export ────────────────────────────────────────────────────────────
# CLONE_EXPORT_CONNECT_TIMEOUT_MS=20000
# CLONE_EXPORT_INVOKE_TIMEOUT_MS=15000

# ── Behavior engine ────────────────────────────────────────────────────────
# BEHAVIOR_ENABLED=true
# BEHAVIOR_TICK_INTERVAL_MS=300000
# BEHAVIOR_BATCH_SIZE=5
# BEHAVIOR_DELAY_MIN_MS=4000
# BEHAVIOR_DELAY_MAX_MS=12000
# BEHAVIOR_WARMUP_GRACE_HOURS=48
# BEHAVIOR_MIN_GAP_MS=1800000
# BEHAVIOR_CURFEW_HOUR_START=23
# BEHAVIOR_CURFEW_HOUR_END=6

# ── Privacy job worker ─────────────────────────────────────────────────────
# PRIVACY_JOB_TICK_MS=5000
# PRIVACY_JOB_CONCURRENCY=3
# PRIVACY_JOB_COOLDOWN_MIN_MS=750
# PRIVACY_JOB_COOLDOWN_MAX_MS=2500

# ── Billing — OxaPay crypto payments ───────────────────────────────────────
# Generate a Merchant API key from https://oxapay.com
OXAPAY_MERCHANT_API_KEY=
OXAPAY_BASE_URL=https://api.oxapay.com/v1
OXAPAY_CALLBACK_URL=https://your-domain.example/api/billing/oxapay/ipn
OXAPAY_RETURN_URL=https://your-domain.example/billing?status=success
OXAPAY_SANDBOX=false
OXAPAY_INVOICE_LIFETIME_MIN=60

# ── Multi-platform — Instagram ─────────────────────────────────────────────
IG_QUEUES_ENABLED=true
IG_SCRAPE_CONCURRENCY=3
IG_MESSAGING_CONCURRENCY=2
IG_WARMUP_CONCURRENCY=1
# IG_WARMUP_ENABLED=true
# IG_LOOKUP_CONCURRENCY=2
IG_MAX_RUNNING_JOBS_PER_USER=20

# Override the IG proxy validator's probe endpoint.
# IG_PROXY_VALIDATE_ENDPOINT=

# ── Multi-platform — Reddit ────────────────────────────────────────────────
# REDDIT_QUEUE_ENABLED=true
# REDDIT_SCRAPE_CONCURRENCY=2

# ── Instagram Lookup / OSINT ───────────────────────────────────────────────
# SERPAPI_KEY=
# LOOKUP_MASK_SALT=ig-lookup-mask-salt-v1
# LOOKUP_BUDGET_USD_CAP_DEFAULT=

# Per-operation cost overrides (USD). Used for budget tracking.
# LOOKUP_COST_DEHASHED=0.0035
# LOOKUP_COST_LEAKCHECK=0.002
# LOOKUP_COST_SNUSBASE=0.002
# LOOKUP_COST_INTELLIGENCEX=0.005
# LOOKUP_COST_HIBP=0
# LOOKUP_COST_WHOISXML=0.005
# LOOKUP_COST_WHOXY=0.003
# LOOKUP_COST_SERPAPI=0.005
# LOOKUP_COST_PIMEYES=0.020
# LOOKUP_COST_TINEYE=0.005
# LOOKUP_COST_TWOCAPTCHA=0.003

# Lookup retention
# LOOKUP_RETENTION_ENABLED=true
# LOOKUP_RETENTION_POLL_MS=3600000
# LOOKUP_SNAPSHOT_RETENTION_DAYS=365
# LOOKUP_JOB_RETENTION_DAYS=90

# Lookup watch worker
# LOOKUP_WATCH_ENABLED=true
# LOOKUP_WATCH_POLL_INTERVAL_MS=60000
# LOOKUP_WATCH_CONCURRENCY=2
# LOOKUP_WATCH_BATCH_SIZE=20

# ── Pagination ─────────────────────────────────────────────────────────────
# MAX_UNBOUNDED_LIST=20000

# ── Deploy metadata (set by docker-compose, not manually) ──────────────────
# DEPLOY_COLOR=
# GIT_SHA=
# GIT_REF=
# BUILD_TIME=
# IMAGE_TAG=

# ── Admin bot (runs inside its own container, shares this env file) ────────
# TELEGRAM_ADMIN_BOT_TOKEN=
# TELEGRAM_ADMIN_IDS=
# UPGRADE_CONFIRM_PIN=
# STATE_DIR=/app/state
# HEARTBEAT_MAX_AGE_MS=90000

# ── CupidBot AI Auto-Responder (Telegram only) ───────────────────────────────
# Get your access token from https://cupidbot.web.app (API route uses normal
# credits and the same token as the Chrome extension).
CUPIDBOT_ACCESS_TOKEN=
# Optional override of the chat-generation endpoint. Defaults to CupidBot's
# downstream chat-generation URL.
# CUPIDBOT_ENDPOINT_URL=https://chat-api.cupidbotofm.ai/api/generateChatResponse
# Worker concurrency for AI reply generation.
# CUPIDBOT_CONCURRENCY=5
# Default delay before sending an AI reply (ms).
# AI_REPLY_DELAY_MS=3000
# Random extra delay added to the base reply delay (ms).
# AI_REPLY_JITTER_MS=2000
# Maximum messages kept in per-chat memory.
# AI_MEMORY_MESSAGE_LIMIT=50
