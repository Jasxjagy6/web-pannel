# =============================================================================
# Frontend .env — copy to frontend/.env and customise.
# Loaded by Vite at build/dev time. Only VITE_-prefixed vars are exposed.
# =============================================================================

# Override the API base URL. Defaults to '/api' (same-origin, proxied by
# Vite dev server or Caddy in production). Set this only when the backend
# runs on a different host/port and you're NOT using a reverse proxy.
# VITE_API_URL=/api

# Override the WebSocket URL. Defaults to the current page origin
# (same host, same protocol). Set this only when the WebSocket endpoint
# is on a different host/port.
# VITE_SOCKET_URL=ws://localhost:3005
